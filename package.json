{
  "name": "memorytree-workflow",
  "version": "0.1.0",
  "type": "module",
  "description": "MemoryTree Skill — transcript import, dedup, indexing, and session continuity for AI coding assistants",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "memorytree": "./dist/cli.js",
    "memorytree-daemon": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli/main.ts",
    "doctor": "node dist/cli.js doctor",
    "pretest:e2e": "npm run build",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test": "vitest run",
    "lint": "eslint src tests --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "commander": "^13.1.0",
    "fast-glob": "^3.3.3",
    "smol-toml": "^1.3.1",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/sql.js": "^1.4.9",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "memfs": "^4.17.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.1.1"
  },
  "files": [
    "dist",
    "assets"
  ]
}
